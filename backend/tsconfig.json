{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "composite": true
  },
  "include": ["."],
  "exclude": ["node_modules"]
}
